  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'f=\"$CLAUDE_TOOL_INPUT_PATH\"; [[ \"$f\" =~ \\.(cpp|hpp|h|cxx|cc)$ ]] && clang-format -i \"$f\" 2>/dev/null || true'"
          }
        ]
      }
    ]
  },
  "model": "claude-sonnet-4-6",
  "env": {
    "BUILD_DIR": "build",
    "ESPPORT": "COM8",
    "IDF_PATH": "C:\\Espressif\\.espressif\\v6.0.1\\esp-idf",
    "IDF_PYTHON_ENV_PATH": "C:\\Espressif\\tools\\python\\v6.0.1\\venv",
    "IDF_TOOLS_PATH": "C:\\Espressif\\tools",
    "ESP_IDF_VERSION": "6.0"
  }
