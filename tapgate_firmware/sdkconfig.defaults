CONFIG_COMPILER_CXX_EXCEPTIONS=n
CONFIG_COMPILER_CXX_RTTI=n
CONFIG_COMPILER_OPTIMIZATION_LEVEL_DEBUG=y
CONFIG_COMPILER_OPTIMIZATION_ASSERTIONS_DISABLE=y
CONFIG_LIBC_NEWLIB_NANO_FORMAT=y
CONFIG_FREERTOS_GENERATE_RUN_TIME_STATS=n
CONFIG_APP_REPRODUCIBLE_BUILD=y

# IWDT timeout extended for JTAG debugging.
# OpenOCD halts the CPU during launch.json setupCommands (set var dbg_ready,
# tbreak, symbol loading). During a CPU halt the IWDT keeps counting; if the
# halt exceeds the default 300 ms the IWDT fires a spurious "Guru Meditation
# Error". 10 s covers GDB symbol-load time.
CONFIG_ESP_INT_WDT_TIMEOUT_MS=10000


# Partition Table
#
# CONFIG_PARTITION_TABLE_SINGLE_APP is not set
# CONFIG_PARTITION_TABLE_SINGLE_APP_LARGE is not set
# CONFIG_PARTITION_TABLE_TWO_OTA is not set
# CONFIG_PARTITION_TABLE_TWO_OTA_LARGE is not set
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions.csv"
# default:
CONFIG_PARTITION_TABLE_FILENAME="partitions.csv"
# default:
CONFIG_PARTITION_TABLE_OFFSET=0x8000
# default:
CONFIG_PARTITION_TABLE_MD5=y
# end of Partition Table
